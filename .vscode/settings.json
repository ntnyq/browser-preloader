{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "cSpell.words": [
    "bumpp",
    "changelogithub",
    "esbuild",
    "oxfmt",
    "oxlint",
    "tsdown",
    "tsgo",
    "vitest"
  ],
  "cSpell.allowCompoundWords": true
}

{
  "name": "browser-preloader",
  "version": "0.1.0",
  "description": "Preload resources in browser, e.g: images.",
  "keywords": [
    "browser",
    "preload",
    "preload-image",
    "preloader"
  ],
  "homepage": "https://github.com/ntnyq/browser-preloader#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/browser-preloader/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/browser-preloader",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@ntnyq/utils": "^0.15.0",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260614.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.8"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.6.0"
}
